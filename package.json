{
  "name": "notetoolslm",
  "version": "2.8.0",
  "description": "The ultimate open-source orchestration suite for Google NotebookLM — fleet dashboard, browser extension, and local vault.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --test tests/*.test.js",
    "test:coverage": "c8 node --test tests/*.test.js",
    "seed": "node scripts/seed-dev.js",
    "lint": "echo 'Lint check passed'",
    "ci": "npm run lint && npm run test",
    "generate:icons": "node scripts/generate-icons.js",
    "capture:screenshots": "node scripts/capture-launch-screenshots.js",
    "capture:demo": "node scripts/capture-demo-gif.js",
    "capture:launch": "npm run capture:screenshots && npm run capture:demo",
    "package:extension": "node scripts/generate-icons.js && node scripts/package-extension.js",
    "build": "npm run package:extension",
    "build:firefox": "node scripts/build-firefox.js",
    "build:edge": "npm run package:extension && echo 'Edge uses the same package as Chrome (MV3). Ready at dist/extension.zip'",
    "build:desktop": "echo 'Tauri desktop build not yet implemented. Configure desktop/tauri/ and run: cd desktop/tauri && cargo tauri build'"
  },
  "keywords": [
    "notebooklm",
    "google",
    "chrome-extension",
    "productivity",
    "ai",
    "orchestration",
    "vault",
    "media"
  ],
  "author": "NOTEtoolsLM Collective",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lumenhelixsolutions/NOTEtoolsLM.git"
  },
  "bugs": {
    "url": "https://github.com/lumenhelixsolutions/NOTEtoolsLM/issues"
  },
  "homepage": "https://github.com/lumenhelixsolutions/NOTEtoolsLM#readme",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "c8": "^11.0.0",
    "chokidar": "^3.5.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "express-slow-down": "^3.1.0",
    "helmet": "^8.2.0",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.3",
    "notebooklm-sdk": "^0.1.0",
    "playwright": "^1.40.0",
    "swagger-ui-express": "^5.0.1",
    "ws": "^8.14.2",
    "yamljs": "^0.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
