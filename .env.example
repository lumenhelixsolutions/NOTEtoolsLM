# NOTEtoolsLM v2 — Environment Configuration
# Copy this file to .env and customize for your setup.

# Server port (default: 3000)
PORT=3000

# Public API base URL for decoupled frontend deployments
# Leave empty when serving dashboard from the same origin
# API_BASE=http://localhost:3000

# NotebookLM SDK session path (auto-detected if left empty)
# NOTEBOOKLM_SESSION_PATH=

# Vault storage directory (default: ./vault-storage)
# VAULT_DIR=./vault-storage

# Ingestion/watch directory (default: ./ingestion)
# INGESTION_DIR=./ingestion

# Data persistence directory (default: ./.data)
# DATA_DIR=./.data
